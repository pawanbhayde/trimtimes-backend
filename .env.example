# Database — PostgreSQL connection string. The ?schema=public sets the default search_path.
DATABASE_URL="postgresql://user:password@localhost:5432/barber_system?schema=public"

# JWT — use separate secrets for access and refresh tokens
JWT_SECRET="your-access-token-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-token-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS — your Next.js (or other) frontend origin
FRONTEND_URL="http://localhost:3000"
