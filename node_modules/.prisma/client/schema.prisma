// Global schema — all models live in the public PostgreSQL schema.
// All shops share the same tables, isolated by tenant_id foreign key.
//
// Commands:
//   prisma migrate dev   → apply migrations
//   prisma generate      → regenerate the Prisma client

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── Tenant (Shop) ────────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  shopName    String       @map("shop_name")
  subdomain   String       @unique
  schemaName  String       @unique @map("schema_name")
  ownerEmail  String       @map("owner_email")
  ownerName   String?      @map("owner_name")
  password    String?
  description String?
  email       String?
  bannerUrl   String?      @map("banner_url")
  phone       String?
  address     String?
  image       String?
  rating      Float        @default(5.0)
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  hours        ShopHours[]
  location     ShopLocation?
  treatments   Treatment[]
  artisans     Artisan[]
  reviews      Review[]
  appointments Appointment[]

  @@map("tenants")
}

// ─── Super Admin ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("super_admins")
}

// ─── Customer (end-user who books appointments) ───────────────────────────────

model Customer {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  fullName  String   @map("full_name")
  email     String   @unique
  phone     String
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("customers")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  role      String
  entityId  String   @map("entity_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

// ─── Shop Management ──────────────────────────────────────────────────────────

model ShopHours {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  day       String
  isOpen    Boolean @map("is_open")
  openTime  String  @map("open_time")
  closeTime String  @map("close_time")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, day])
  @@map("shop_hours")
}

model ShopLocation {
  id          String  @id @default(uuid())
  tenantId    String  @unique @map("tenant_id")
  street      String?
  city        String?
  state       String?
  zip         String?
  country     String?
  latitude    Float?
  longitude   Float?
  mapEmbedUrl String? @map("map_embed_url")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("shop_locations")
}

model Treatment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  price       Float
  duration    Int
  status      String   @default("Active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("treatments")
}

model Artisan {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  specialty String?
  bio       String?
  avatarUrl String?  @map("avatar_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("artisans")
}

model Review {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  customerName String   @map("customer_name")
  rating       Int
  comment      String?
  isFeatured   Boolean  @default(false) @map("is_featured")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─── Appointments (universal — all shops share this table) ───────────────────

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  customerId      String            @map("customer_id")
  treatmentId     String            @map("treatment_id")
  artisanId       String?           @map("artisan_id")
  appointmentDate DateTime          @map("appointment_date")
  appointmentTime String            @map("appointment_time")
  status          AppointmentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  artisan   Artisan?  @relation(fields: [artisanId], references: [id])

  @@map("appointments")
}
